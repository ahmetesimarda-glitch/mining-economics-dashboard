# =============================================
# ENVIRONMENT VARIABLES (TEMPLATE)
# Copy this file to .env and fill in the values
# =============================================

# PostgreSQL connection string (REQUIRED)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/mining_db"

# Application URL (required for production deploys)
NEXTAUTH_URL="http://localhost:3000"

# (Optional) API key for AI Analysis
# Works with any OpenAI-compatible provider
# Without this key the app still runs; only the AI tab is unavailable
# ABACUSAI_API_KEY="sk-..."

# (Optional) Chrome/Chromium path for local PDF generation
# Set when Chromium is not on PATH (Railway/Docker usually install system Chromium)
# PUPPETEER_EXECUTABLE_PATH="/usr/bin/chromium"
# CHROME_PATH="/usr/bin/google-chrome-stable"

# (Temporary, pre-auth only) Enable internal demo-analytics UI + summary API in production.
# Local development enables these automatically when NODE_ENV !== 'production'.
# REMOVE this flag when Authentication + Administrator RBAC ships (see ai-docs/ROADMAP.md §5).
# Until then, keep this gate — do not replace it with a standalone access-control fix.
# INTERNAL_ANALYTICS_ENABLED="true"
