# =============================================
# ORTAM DEĞİŞKENLERİ (ŞABLON)
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# =============================================

# PostgreSQL Veritabanı Bağlantı Dizesi (ZORUNLU)
# Format: postgresql://KULLANICI:SIFRE@HOST:PORT/VERITABANI_ADI
DATABASE_URL="postgresql://postgres:sifreniz@localhost:5432/mining_db"

# Uygulama URL'si (production deploy için)
NEXTAUTH_URL="http://localhost:3000"

# (İsteğe bağlı) AI Analiz için API anahtarı
# OpenAI uyumlu herhangi bir servis kullanabilirsiniz
# Bu olmadan uygulama çalışır, sadece AI sekmesi çalışmaz
# ABACUSAI_API_KEY="sk-..."

# (İsteğe bağlı) PDF raporu için HTML2PDF servisi
# Puppeteer/Playwright ile değiştirebilirsiniz
# HTML2PDF_API_URL="..."
